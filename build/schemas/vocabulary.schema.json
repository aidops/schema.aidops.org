{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://publicschema.org/schemas/vocabulary.schema.json",
  "title": "PublicSchema Vocabulary",
  "type": "object",
  "required": ["id", "maturity", "definition", "values"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "kebab-case vocabulary identifier"
    },
    "maturity": {
      "type": "string",
      "enum": ["draft", "candidate", "normative"]
    },
    "label": {
      "$ref": "#/$defs/multilingual_text",
      "description": "Human-readable display name in each supported language"
    },
    "definition": {
      "$ref": "#/$defs/multilingual_text"
    },
    "standard": {
      "type": ["object", "null"],
      "properties": {
        "name": { "type": "string" },
        "uri": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "values": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/vocab_value"
      },
      "minItems": 1
    },
    "system_mappings": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/system_mapping"
      }
    },
    "external_equivalents": {
      "type": ["object", "null"],
      "description": "Mappings to equivalent classes or properties in external ontologies (e.g. SEMIC Core Vocabularies)",
      "additionalProperties": {
        "$ref": "#/$defs/external_equivalent"
      }
    },
    "same_standard_systems": {
      "type": "array",
      "items": { "type": "string" }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "uri", "relationship"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "uri": { "type": "string" },
          "relationship": {
            "type": "string",
            "enum": ["superset", "subset", "partial_overlap", "structural_pattern", "prose_guidance"]
          },
          "machine_readable": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "see_also": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vocabulary", "note"],
        "additionalProperties": false,
        "properties": {
          "vocabulary": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "vc_guidance": {
      "type": "string",
      "description": "Guidance for Verifiable Credential use of this vocabulary"
    },
    "external_values": {
      "type": "boolean",
      "description": "When true, the HTML page hides the values table and points to the standard instead. Downloads still include all values."
    },
    "domain": {
      "type": ["string", "null"],
      "description": "Domain namespace. Null or omitted for universal vocabularies."
    },
    "sync": {
      "type": "object",
      "required": ["source_url", "format"],
      "additionalProperties": false,
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri",
          "description": "URL to download the authoritative standard data from"
        },
        "format": {
          "type": "string",
          "enum": ["fhir-codesystem", "iso-xml", "csv", "tsv", "semicolon-delimited", "github-json", "isco-json"],
          "description": "Parser to use for the downloaded data"
        },
        "last_synced": {
          "type": "string",
          "format": "date",
          "description": "Date of the most recent sync (ISO 8601)"
        }
      }
    }
  },
  "$defs": {
    "multilingual_text": {
      "type": "object",
      "required": ["en"],
      "properties": {
        "en": { "type": "string" },
        "fr": { "type": "string" },
        "es": { "type": "string" }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "system_mapping": {
      "type": "object",
      "required": ["values"],
      "additionalProperties": false,
      "properties": {
        "vocabulary_name": {
          "type": "string",
          "description": "Name the external system uses for this vocabulary"
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/system_mapping_value"
          },
          "minItems": 1
        },
        "unmapped_canonical": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Canonical value codes not covered by this system"
        },
        "note": {
          "type": "string",
          "description": "Context note about the overall mapping for this system"
        }
      }
    },
    "system_mapping_value": {
      "type": "object",
      "required": ["code", "label", "maps_to"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier used in the external system"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable label the system uses"
        },
        "maps_to": {
          "type": ["string", "null"],
          "description": "Canonical value code, or null if no equivalent"
        },
        "unmapped_reason": {
          "type": "string",
          "enum": ["no_equivalent", "not_yet_mapped", "out_of_scope", "context_dependent"],
          "description": "Why this system value has no canonical equivalent. Required when maps_to is null."
        },
        "note": {
          "type": "string",
          "description": "Context note explaining the mapping rationale"
        },
        "migration_note": {
          "type": "string",
          "description": "Note about planned changes to this mapping (e.g. when a deprecated code is removed)"
        }
      }
    },
    "external_equivalent": {
      "type": "object",
      "required": ["label", "match"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "description": "Human-readable name in the external ontology"
        },
        "uri": {
          "type": "string",
          "format": "uri",
          "description": "Full URI of the equivalent in the external ontology"
        },
        "match": {
          "type": "string",
          "enum": ["exact", "close", "broad", "narrow", "related", "name_match", "none"],
          "description": "Semantic match quality. SKOS-aligned: exact, close, broad, narrow, related. Non-SKOS extensions: name_match, none."
        },
        "vocabulary": {
          "type": "string",
          "description": "Which vocabulary or ontology module this comes from"
        },
        "note": {
          "type": "string",
          "description": "Semantic rationale for the match quality"
        }
      }
    },
    "vocab_value": {
      "type": "object",
      "required": ["code", "label"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "domain": {
          "type": "string",
          "description": "Domain scope for this value (e.g. 'sp' for social protection)"
        },
        "label": {
          "$ref": "#/$defs/multilingual_text"
        },
        "standard_code": {
          "type": "string"
        },
        "definition": {
          "$ref": "#/$defs/multilingual_text"
        },
        "notes": {
          "type": "object",
          "properties": {
            "en": { "type": "string" }
          },
          "additionalProperties": { "type": "string" }
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "description": "Depth in the hierarchy (1=top). Present only for hierarchical vocabularies."
        },
        "parent_code": {
          "type": "string",
          "description": "standard_code of the parent value in the hierarchy."
        },
        "deprecated": {
          "type": "boolean",
          "description": "Whether this value is deprecated and will be removed in a future version"
        },
        "deprecated_note": {
          "type": "string",
          "description": "Guidance for migrating away from this deprecated value"
        },
        "group_type_applicability": {
          "type": "array",
          "description": "Advisory list of group-type codes this value is intended for. Informational only; not enforced by schema validation.",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          }
        }
      }
    }
  }
}
