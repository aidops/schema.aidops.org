---
/**
 * Inline PublicSchema mark. Rendered next to links that point to
 * publicschema.org so readers can tell at a glance that the target
 * is defined in the upstream schema rather than here.
 */
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
const label = t('concept_detail.publicschema_hint');
---

<svg
  class="ps-mark"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 512 512"
  role="img"
  aria-label={label}
>
  <title>{label}</title>
  <defs>
    <linearGradient id="ps-mark-bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#1e3a5f" />
      <stop offset="100%" stop-color="#15294a" />
    </linearGradient>
  </defs>
  <rect width="512" height="512" rx="80" fill="url(#ps-mark-bg)" />
  <g stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none" opacity="0.35">
    <line x1="280" y1="165" x2="360" y2="128" />
    <line x1="292" y1="198" x2="390" y2="210" />
    <line x1="278" y1="245" x2="358" y2="310" />
    <line x1="360" y1="128" x2="390" y2="210" />
  </g>
  <g fill="white">
    <circle cx="360" cy="128" r="15" />
    <circle cx="390" cy="210" r="12" />
    <circle cx="358" cy="310" r="11" />
  </g>
  <text
    x="185"
    y="345"
    text-anchor="middle"
    dominant-baseline="auto"
    font-family="'IBM Plex Sans', 'Helvetica Neue', Arial, sans-serif"
    font-weight="700"
    font-size="320"
    fill="white"
  >P</text>
</svg>

<style>
  .ps-mark {
    display: inline-block;
    width: 0.95em;
    height: 0.95em;
    vertical-align: -0.15em;
    margin-right: 0.3em;
    border-radius: 0.15em;
    flex-shrink: 0;
  }
</style>
