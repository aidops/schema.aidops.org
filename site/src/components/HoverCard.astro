---
/**
 * Global hover-card container + panel markup. Mount once in Base.astro.
 *
 * Rendering is server-side empty. The `hover-card.ts` script takes over on
 * the client: it attaches delegated listeners to every `[data-preview-key]`
 * link, fetches `/preview/{locale}.json` on first hover, and fills the panel.
 *
 * Locale + i18n strings are exposed via `data-*` attributes on the container
 * so the script has no compile-time dependency on the Astro i18n layer.
 */
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const locale = getLangFromUrl(Astro.url);
const t = useTranslations(locale);
---

<div
  class="hover-card-container"
  data-locale={locale}
  data-defined-in-ps={t('concept_detail.publicschema_hint')}
  data-open-link={t('hover_card.open_link')}
  data-fallback-tag={t('hover_card.fallback_tag')}
  data-property-type={t('hover_card.property_type')}
  data-property-vocabulary={t('hover_card.property_vocabulary')}
  data-badge-draft={t('hover_card.badge_draft')}
  data-badge-candidate={t('hover_card.badge_candidate')}
  data-badge-stable={t('hover_card.badge_stable')}
  hidden
>
  <div
    id="hover-card-panel"
    class="hover-card-panel"
    role="tooltip"
  ></div>
</div>

<script src="../scripts/hover-card.ts"></script>

<style is:global>
  .hover-card-container {
    display: contents;
  }
  .hover-card-container[hidden] .hover-card-panel {
    display: none;
  }

  .hover-card-panel {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 1000;
    max-width: 360px;
    min-width: 220px;
    padding: 0.8rem 0.95rem;
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.45;
    pointer-events: auto;
    opacity: 0;
    transform: translateY(-2px);
    transition: opacity 120ms ease-out, transform 120ms ease-out;
  }
  .hover-card-container.hc-open .hover-card-panel {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hover-card-panel {
      transition: none;
    }
  }

  .hc-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    margin-bottom: 0.3rem;
    word-break: break-word;
  }

  .hc-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-bottom: 0.45rem;
  }

  .hc-badge {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: var(--radius-pill);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: capitalize;
    line-height: 1.4;
  }
  .hc-badge-ps {
    background: #eaf0f9;
    color: #1e3a5f;
  }
  .hc-badge-maturity-draft {
    background: var(--color-draft-bg);
    color: var(--color-draft);
  }
  .hc-badge-maturity-candidate {
    background: var(--color-candidate-bg);
    color: var(--color-candidate);
  }
  .hc-badge-maturity-stable {
    background: var(--color-normative-bg);
    color: var(--color-normative);
  }
  .hc-badge-fallback {
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-weight: 500;
    text-transform: uppercase;
  }

  .hc-def {
    color: var(--color-text);
    margin-bottom: 0.5rem;
    word-wrap: break-word;
  }

  .hc-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 0.55rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
  .hc-meta .hc-meta-key {
    font-weight: 600;
    color: var(--color-text);
  }
  .hc-meta code {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    background: var(--color-surface);
    padding: 0.05rem 0.35rem;
    border-radius: var(--radius-sm);
  }

  .hc-cta {
    display: inline-block;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
  }
  .hc-cta:hover,
  .hc-cta:focus-visible {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }
</style>
