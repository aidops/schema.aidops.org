---
import Base from '../../layouts/Base.astro';
import ExpandableDefinition from '../ExpandableDefinition.astro';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { useTranslations, localePath } from '../../i18n/utils';
import { loadVocabulary } from '../../data/vocabulary';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

const vocab = loadVocabulary();
const maturityRank: Record<string, number> = { normative: 0, candidate: 1, draft: 2 };
const byMaturityThenName = (a: { maturity: string; id: string }, b: { maturity: string; id: string }) =>
  (maturityRank[a.maturity] ?? 9) - (maturityRank[b.maturity] ?? 9) || a.id.localeCompare(b.id);
const conceptLabel = (c: { id: string; label?: { en?: string; fr?: string; es?: string } }) =>
  c.label?.[locale] ?? c.label?.en ?? c.id;
const showCanonical = locale !== defaultLocale;
const concepts = Object.values(vocab.concepts).sort(byMaturityThenName);
---
<Base title={t('concepts.page_title')} description={t('concepts.page_subtitle')} locale={locale}>
  <div class="page-header">
    <nav class="breadcrumb" aria-label={t('breadcrumb.home')}>
      <a href={localePath('/', locale)}>{t('breadcrumb.home')}</a><span class="separator">/</span>{t('common.concepts')}
    </nav>
    <h1>{t('concepts.page_title')}</h1>
    <p class="subtitle">{t('concepts.page_subtitle')}</p>
  </div>

  <table class="data-table mobile-card-table">
    <thead>
      <tr>
        <th>{t('concepts.table.concept')}</th>
        <th>{t('concepts.table.definition')}</th>
      </tr>
    </thead>
    <tbody>
      {concepts.map((c) => (
        <tr>
          <td>
            <a href={localePath(c.path, locale)}>{conceptLabel(c)}</a>
            {showCanonical && conceptLabel(c) !== c.id && <span class="canonical-hint">{c.id}</span>}
          </td>
          <td data-label={t('concepts.table.definition')}>
            <ExpandableDefinition text={c.definition[locale] ?? c.definition.en ?? ''} />
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
