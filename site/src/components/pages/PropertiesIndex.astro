---
import Base from '../../layouts/Base.astro';
import { defaultLocale, type Locale } from '../../i18n/languages';
import { useTranslations, localePath } from '../../i18n/utils';
import { loadVocabulary } from '../../data/vocabulary';
import { isOwned, externalHref } from '../../data/concept-utils';
import PsMark from '../PsMark.astro';

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props;
const t = useTranslations(locale);

const vocab = loadVocabulary();
const maturityRank: Record<string, number> = { normative: 0, candidate: 1, draft: 2 };
const byMaturityThenName = (a: { maturity: string; id: string }, b: { maturity: string; id: string }) =>
  (maturityRank[a.maturity] ?? 9) - (maturityRank[b.maturity] ?? 9) || a.id.localeCompare(b.id);
const properties = Object.values(vocab.properties).filter(isOwned).sort(byMaturityThenName);
---
<Base title={t('properties.page_title')} description={t('properties.page_subtitle')} locale={locale}>
  <div class="page-header">
    <nav class="breadcrumb" aria-label={t('breadcrumb.home')}>
      <a href={localePath('/', locale)}>{t('breadcrumb.home')}</a><span class="separator">/</span>{t('common.properties')}
    </nav>
    <h1>{t('properties.page_title')}</h1>
    <p class="subtitle">{t('properties.page_subtitle')}</p>
  </div>

  <table class="data-table mobile-card-table">
    <thead>
      <tr>
        <th>{t('properties.table.property')}</th>
        <th>{t('properties.table.type')}</th>
        <th>{t('properties.table.used_by')}</th>
      </tr>
    </thead>
    <tbody>
      {properties.map((p) => {
        const conceptRef = p.type.match(/^concept:(.+)$/)?.[1];
        const refConcept = conceptRef ? vocab.concepts[conceptRef] : undefined;
        return (
          <tr>
            <td><a href={localePath(p.path, locale)}>{p.label?.[locale] ?? p.label?.en ?? p.id}</a></td>
            <td data-label={t('properties.table.type')}>{conceptRef
              ? isOwned(refConcept)
                ? <a href={localePath(refConcept!.path, locale)}><code>{p.type}</code></a>
                : <a href={externalHref(refConcept) ?? `https://publicschema.org/${conceptRef}`} target="_blank" rel="noopener noreferrer"><PsMark /><code>{p.type}</code></a>
              : <code>{p.type}</code>
            }</td>
            <td data-label={t('properties.table.used_by')}>{p.used_by.join(", ")}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</Base>
