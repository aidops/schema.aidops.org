---
import VocabDetail from '../../components/pages/VocabDetail.astro';
import { loadVocabulary } from '../../data/vocabulary';

export function getStaticPaths() {
  const vocab = loadVocabulary();
  return Object.keys(vocab.vocabularies).map((key) => ({ params: { vocab: key } }));
}
---
<VocabDetail vocab={Astro.params.vocab!} />
